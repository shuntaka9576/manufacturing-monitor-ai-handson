{
  "name": "seizo-ai-handson",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "lefthook install",
    "lint": "turbo run lint:spell lint:text lint:format",
    "lint:spell": "cspell lint --no-progress \"**\"",
    "lint:text": "textlint README.md \"kiro/{README,SETUP}.md\" claude-code/README.md \"kiro/{ch1,ch2,ch3,ch4,ch5,ch5_fin}/README.md\" \"claude-code/{ch1,ch2,ch4,ch5,ch5_fin}/README.md\"",
    "lint:format": "prettier --check \"**/*.md\"",
    "fix": "turbo run fix:text fix:format",
    "fix:text": "textlint --fix README.md \"kiro/{README,SETUP}.md\" claude-code/README.md \"kiro/{ch1,ch2,ch3,ch4,ch5,ch5_fin}/README.md\" \"claude-code/{ch1,ch2,ch4,ch5,ch5_fin}/README.md\"",
    "fix:format": "prettier --write \"**/*.md\""
  },
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "cspell": "^9.7.0",
    "lefthook": "^2.1.3",
    "prettier": "^3.8.1",
    "textlint": "^15.5.2",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "turbo": "^2.8.14"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
